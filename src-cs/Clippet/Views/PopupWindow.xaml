<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Clippet.Views.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Clippet.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" MinHeight="56" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid x:Name="TitleBar" Grid.Row="0" Padding="14,0">
            <TextBlock x:Name="TitleText" Text="Clippet" VerticalAlignment="Center"
                       FontSize="14" FontWeight="SemiBold" />
            <Button x:Name="CloseButton" Click="CloseButton_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Stretch"
                    Width="46" Background="Transparent" BorderThickness="0" Padding="0"
                    CornerRadius="0">
                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE8BB;" FontSize="12" />
            </Button>
        </Grid>

        <!-- Search box -->
        <Grid x:Name="SearchPanel" Grid.Row="1" Margin="12,4,12,8" Height="40" CornerRadius="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <FontIcon x:Name="SearchIcon" Grid.Column="0" Margin="12,0,8,0"
                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE721;" FontSize="14" />
            <TextBox x:Name="SearchBox" Grid.Column="1" BorderThickness="0" Background="Transparent"
                     PlaceholderText="Search clipboard…" VerticalAlignment="Center"
                     TextChanged="SearchBox_TextChanged" KeyDown="SearchBox_KeyDown" />
        </Grid>

        <!-- History list -->
        <ListView x:Name="HistoryList" Grid.Row="2" Margin="6,0,6,2"
                  SelectionMode="Single"
                  ContainerContentChanging="HistoryList_ContainerContentChanging"
                  DoubleTapped="HistoryList_DoubleTapped"
                  RightTapped="HistoryList_RightTapped"
                  KeyDown="HistoryList_KeyDown">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="6,0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:RowVM">
                    <Grid x:Name="RowRoot" Height="{x:Bind RowHeight}" Padding="6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="22" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="{x:Bind TagText}" Foreground="{x:Bind TagBrush}"
                                       FontSize="11" FontFamily="Consolas,Cascadia Mono" />
                        </Border>

                        <Image x:Name="ThumbImage" Grid.Column="1" Source="{x:Bind Thumb, Mode=OneWay}"
                               Width="68" Height="68" Stretch="Uniform" Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Visibility="{x:Bind ThumbVisibility}" />

                        <TextBlock x:Name="PreviewText" Grid.Column="2" Text="{x:Bind Preview}"
                                   Foreground="{x:Bind TextBrush}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" FontSize="13" />

                        <TextBlock Grid.Column="3" Text="{x:Bind TimeText}" Foreground="{x:Bind SubtextBrush}"
                                   VerticalAlignment="Center" Margin="8,0" FontSize="11" />

                        <Button Grid.Column="4" Click="PinButton_Click" Background="Transparent"
                                BorderThickness="0" Padding="0" Width="22" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind PinGlyph}" Foreground="{x:Bind PinBrush}" FontSize="15" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer -->
        <StackPanel x:Name="Footer" Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,4,14,8" Spacing="4">
            <Button x:Name="ThemeButton" Click="ThemeButton_Click" Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="36" Height="36">
                <FontIcon x:Name="ThemeIcon" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE706;" FontSize="15" />
                <ToolTipService.ToolTip>
                    <ToolTip x:Name="ThemeTip" Content="Switch theme" />
                </ToolTipService.ToolTip>
            </Button>
            <Button Click="ClearButton_Click" Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="36" Height="36"
                    ToolTipService.ToolTip="Clear History">
                <FontIcon x:Name="ClearIcon" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="15" />
            </Button>
            <Button Click="SettingsButton_Click" Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="36" Height="36"
                    ToolTipService.ToolTip="Settings">
                <FontIcon x:Name="SettingsIcon" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="15" />
            </Button>
            <Button Click="AboutButton_Click" Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="36" Height="36"
                    ToolTipService.ToolTip="About">
                <FontIcon x:Name="AboutIcon" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE946;" FontSize="15" />
            </Button>
            <Button Click="QuitButton_Click" Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="36" Height="36"
                    ToolTipService.ToolTip="Quit">
                <FontIcon x:Name="QuitIcon" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE7E8;" FontSize="15" />
            </Button>
        </StackPanel>
    </Grid>
</Window>
